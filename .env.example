# Copy this file to .env and fill in real values before deploy.

# OAuth2 (Google)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# App security (RSA Key Pair for JWT)
# For local dev, you can set ALLOW_EPHEMERAL_KEYS=true to auto-generate.
# In production, ALLOW_EPHEMERAL_KEYS=false (default) and these MUST be provided.
ALLOW_EPHEMERAL_KEYS=true
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
ADMIN_ALLOWED_EMAILS=

# Data stores
NEO4J_PASSWORD=replace-with-strong-neo4j-password
REDIS_PASSWORD=replace-with-strong-redis-password
POSTGRES_PASSWORD=replace-with-strong-postgres-password
POSTGRES_USER=postgres
POSTGRES_DB=exam_db

# Gemini AI
GEMINI_API_KEY=your-gemini-api-key

# Runtime URLs
FRONTEND_URL=http://localhost:5173
VITE_API_BASE_URL=http://localhost:8080
VITE_EXAM_API_BASE_URL=http://localhost:8081

# Cookie flags
COOKIE_SECURE=false

# Docker Group ID for sandbox (use 'stat -c %g /var/run/docker.sock' on host)
DOCKER_GROUP_ID=
